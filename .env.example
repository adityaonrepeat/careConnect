# ---- CareConnect environment variables ----
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# All three are SERVER-ONLY (no NEXT_PUBLIC_ prefix) so they never reach the browser.

# Google Gemini API key - free tier from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co  (Project Settings → API)
SUPABASE_URL=

# Supabase anon/public key (Project Settings → API). Used only server-side, behind an
# Row Level Security policy - see README for the table SQL.
SUPABASE_ANON_KEY=
